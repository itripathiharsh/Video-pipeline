# =========================
# ENVIRONMENT
# =========================
ENV=local

# =========================
# AWS CONFIG (FOR PROD)
# =========================
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_DEFAULT_REGION=ap-south-1

# =========================
# S3 CONFIG
# =========================
S3_BUCKET=your-s3-bucket-name

# =========================
# DYNAMODB
# =========================
DYNAMODB_TABLE=cctv-events

# =========================
# LOGGING
# =========================
LOG_LEVEL=INFO

# =========================
# OPTIONAL (FUTURE)
# =========================
USE_GPU=false
BATCH_SIZE=8